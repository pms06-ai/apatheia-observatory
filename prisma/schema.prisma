generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Core Entities ──────────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now()) @map("created_at")

  articles       ArticleTopic[]
  stories        Story[]
  statements     Statement[]
  positionDrifts PositionDrift[]

  @@map("topics")
}

model Actor {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  type        String   @default("politician") // politician | journalist | outlet
  party       String?
  bloc        String?
  role        String?
  bio         String?
  summary     String?
  positioning String?
  photoUrl    String?  @map("photo_url")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  articleActors  ArticleActor[]
  statements     Statement[]
  contradictionsA Contradiction[] @relation("ContradictionActorA")
  positionDrifts PositionDrift[]

  @@map("actors")
}

model Source {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  type        String   @default("outlet")
  biasRating  Float    @default(0) @map("bias_rating") // -1.0 to +1.0
  reliability Float    @default(0)
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")

  articles Article[]

  @@map("sources")
}

// ─── Articles & Processing ──────────────────────────────────────────────

model Article {
  id          String                       @id @default(cuid())
  sourceId    String                       @map("source_id")
  url         String                       @unique
  title       String
  content     String?
  author      String?
  publishedAt DateTime                     @map("published_at")
  embedding   Unsupported("vector(768)")?
  processed   Boolean                      @default(false)
  createdAt   DateTime                     @default(now()) @map("created_at")

  source        Source          @relation(fields: [sourceId], references: [id])
  topics        ArticleTopic[]
  actors        ArticleActor[]
  biasScores    BiasScore[]
  storyArticles StoryArticle[]

  @@map("articles")
}

model ArticleTopic {
  articleId String @map("article_id")
  topicId   String @map("topic_id")
  relevance Float  @default(1.0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([articleId, topicId])
  @@map("article_topics")
}

model ArticleActor {
  articleId   String @map("article_id")
  actorId     String @map("actor_id")
  mentionType String @default("mention") @map("mention_type")
  sentiment   Float  @default(0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  actor   Actor   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@id([articleId, actorId])
  @@map("article_actors")
}

model BiasScore {
  id         String @id @default(cuid())
  articleId  String @map("article_id")
  dimension  String // political_lean | framing | emphasis | omission
  score      Float
  confidence Float  @default(0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("bias_scores")
}

// ─── Stories & Coverage ─────────────────────────────────────────────────

model Story {
  id           String                       @id @default(cuid())
  topicId      String                       @map("topic_id")
  headline     String
  summary      String?
  firstSeen    DateTime                     @map("first_seen")
  articleCount Int                          @default(0) @map("article_count")
  embedding    Unsupported("vector(768)")?
  createdAt    DateTime                     @default(now()) @map("created_at")

  topic         Topic          @relation(fields: [topicId], references: [id])
  storyArticles StoryArticle[]
  coverageGaps  CoverageGap[]

  @@map("stories")
}

model StoryArticle {
  storyId   String @map("story_id")
  articleId String @map("article_id")

  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([storyId, articleId])
  @@map("story_articles")
}

model CoverageGap {
  id              String   @id @default(cuid())
  storyId         String   @map("story_id")
  gapType         String   @map("gap_type")
  sourcesCovering String[] @map("sources_covering")
  sourcesMissing  String[] @map("sources_missing")
  severity        String   @default("low")
  createdAt       DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@map("coverage_gaps")
}

// ─── Statements & Contradictions ────────────────────────────────────────

model Statement {
  id        String                       @id @default(cuid())
  actorId   String                       @map("actor_id")
  topicId   String                       @map("topic_id")
  text      String
  sourceUrl String?                      @map("source_url")
  statedAt  DateTime                     @map("stated_at")
  embedding Unsupported("vector(768)")?
  createdAt DateTime                     @default(now()) @map("created_at")

  actor Actor @relation(fields: [actorId], references: [id])
  topic Topic @relation(fields: [topicId], references: [id])

  contradictionsAsA Contradiction[] @relation("ContradictionStatementA")
  contradictionsAsB Contradiction[] @relation("ContradictionStatementB")

  @@map("statements")
}

model Contradiction {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  statementAId String?  @map("statement_a_id")
  statementBId String?  @map("statement_b_id")
  type         String   // Cross-actor contradiction | Temporal contradiction | Internal tension
  severity     String   @default("medium")
  title        String
  summary      String
  tension      String   @default("")
  dateRange    String   @default("") @map("date_range")
  themes       String[]
  createdAt    DateTime @default(now()) @map("created_at")

  actor      Actor      @relation("ContradictionActorA", fields: [actorId], references: [id])
  statementA Statement? @relation("ContradictionStatementA", fields: [statementAId], references: [id])
  statementB Statement? @relation("ContradictionStatementB", fields: [statementBId], references: [id])

  @@map("contradictions")
}

// ─── Position Tracking ──────────────────────────────────────────────────

model PositionDrift {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  topicId      String   @map("topic_id")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  fromPosition String   @map("from_position")
  toPosition   String   @map("to_position")
  createdAt    DateTime @default(now()) @map("created_at")

  actor Actor @relation(fields: [actorId], references: [id])
  topic Topic @relation(fields: [topicId], references: [id])

  @@map("position_drift")
}

// ─── Themes ─────────────────────────────────────────────────────────────

model Theme {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  parentId String? @map("parent_id")

  parent   Theme?  @relation("ThemeHierarchy", fields: [parentId], references: [id])
  children Theme[] @relation("ThemeHierarchy")

  evidenceThemes EvidenceTheme[]

  @@map("themes")
}

model EvidenceTheme {
  evidenceId   String @map("evidence_id")
  evidenceType String @map("evidence_type") // article | statement
  themeId      String @map("theme_id")

  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([evidenceId, evidenceType, themeId])
  @@map("evidence_themes")
}
