{
  "version": 2,
  "builds": [
    {
      "src": "api/dashboard.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/dashboard",
      "dest": "/api/dashboard.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
